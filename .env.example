# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIBE_FALLBACK_MODEL=whisper-1

# Notion
NOTION_TOKEN=
NOTION_TASKS_DATABASE_ID=be9d26fe652b474696cd5de0118b1210
NOTION_STUDY_DATABASE_ID=4e27e10ca2bf44a08b4c8f86c7a125bd
NOTION_PROJECTS_DATABASE_ID=bbb501a6933941b4837afff250479f0e
NOTION_STREAMS_DATABASE_ID=cd865f3c143842e8b28843c7d02fc4ae

# Runtime behavior
HOST=0.0.0.0
PORT=8080
CONFIDENCE_THRESHOLD=0.70
PENDING_STORE_PATH=data/pending.json
RECENT_STORE_PATH=data/recent.json
TIMEZONE=America/Mexico_City

# Full TASKS <-> Todoist sync. It starts only when both Notion and Todoist tokens are configured.
TODOIST_ENABLED=true
TODOIST_API_TOKEN=
TODOIST_WEBHOOK_SECRET=
TODOIST_SYNC_INTERVAL_SECONDS=300
TODOIST_SYNC_ON_START=true
TODOIST_SYNC_PAUSED=false
# observe reads both systems and writes only a local inventory snapshot/report.
# Change to write only after the dry-run report and canary project are approved.
TODOIST_SYNC_MODE=observe
TODOIST_ALLOW_PROJECT_CREATE=false
TODOIST_ALLOW_TASK_CREATE=false
TODOIST_ALLOW_TASK_MOVE=false
TODOIST_ALLOW_LABEL_WRITE=false
TODOIST_ALLOW_STATUS_WRITE=false
TODOIST_ALLOW_MISSING_CANCEL=false
TODOIST_MAX_TASK_MOVES=10
TODOIST_SNAPSHOT_PATH=data/todoist_inventory_snapshot.json
TODOIST_SYNC_STATE_PATH=data/todoist_sync_state.json
TASK_SYNC_SECRET=
TODOIST_COMPLETED_SINCE=2007-01-01
